{
  "manifest_version": 3,
  "name": "Hover Image Preview",
  "version": "1.1.3",
  "description": "Image previews on hover + word definitions. Free tier with premium features.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["storage.js", "contentScript.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["<all_urls>"],
  "permissions": ["contextMenus", "storage"],
  "options_page": "options.html"
}
